# Base URL of the API. Leave empty in dev to use the Vite proxy.
# In production set to your Render URL, e.g. https://ok-strojevi-api.onrender.com
VITE_API_URL=

# Google Maps JavaScript API key. Needs the Maps JavaScript, Places, and
# Geocoding APIs enabled. Used by the Gradilište location picker.
VITE_GOOGLE_MAPS_API_KEY=
